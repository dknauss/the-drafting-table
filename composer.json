{
    "name": "dpknauss/the-drafting-table",
    "description": "Quality tooling for The Drafting Table block theme.",
    "type": "wordpress-theme",
    "license": "GPL-2.0-or-later",
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^9.6",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "scripts": {
        "lint:php": "phpcs --standard=phpcs.xml.dist",
        "lint:php:fix": "phpcbf --standard=phpcs.xml.dist",
        "test:phpunit": "phpunit --configuration=phpunit.xml.dist"
    },
    "config": {
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
